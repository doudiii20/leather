         <widget class="QWidget" name="pageAccueil">
          <property name="styleSheet">
           <string notr="true">#pageAccueil {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #faf9f7, stop:1 #f0ebe4);
}
#pageAccueil #loginBrandPanel {
  background-color: rgba(245, 239, 230, 0.65);
  border-right: 1px solid #dcd4c8;
}
#pageAccueil #loginCard {
  background-color: #ffffff;
  border: 1px solid rgba(210, 200, 186, 0.95);
  border-radius: 18px;
}
#pageAccueil #loginFieldUser,
#pageAccueil #loginFieldPass {
  background-color: #fcfcfb;
  border: 1px solid #d4cec4;
  border-radius: 11px;
  min-height: 50px;
}
#pageAccueil #loginFieldUser[loginFocus=&quot;true&quot;],
#pageAccueil #loginFieldPass[loginFocus=&quot;true&quot;] {
  border: 2px solid #8b5e3c;
  background-color: #fffefb;
}
#pageAccueil #loginFieldUser QLineEdit,
#pageAccueil #loginFieldPass QLineEdit {
  border: none;
  background: transparent;
  padding: 12px 8px;
  font: 11pt &quot;Segoe UI&quot;;
  color: rgb(45, 35, 28);
  selection-background-color: #d4b896;
}
#pageAccueil #loginIconUser,
#pageAccueil #loginIconPass {
  color: #7a5a38;
  font-size: 18px;
  background: transparent;
}
#pageAccueil #loginFormTitle {
  color: rgb(72, 38, 8);
  font: 700 22px &quot;Segoe UI&quot;;
  letter-spacing: 0.5px;
}
#pageAccueil #loginFormSubtitle {
  color: #6b6155;
  font: 10pt &quot;Segoe UI&quot;;
}
#pageAccueil #loginBrandTagline {
  color: #7a5c3a;
  font: 600 13px &quot;Segoe UI&quot;;
}
#pageAccueil #loginBrandBody {
  color: rgba(55, 44, 34, 0.92);
  font: 11pt &quot;Segoe UI&quot;;
}
#pageAccueil #loginSignupHint {
  color: #6b6155;
  font: 9pt &quot;Segoe UI&quot;;
}
#pageAccueil QPushButton#btnAjouter_8 {
  background-color: #5d2e06;
  color: #ffffff;
  border: none;
  border-radius: 11px;
  padding: 12px 20px;
  font: 600 11pt &quot;Segoe UI&quot;;
  min-height: 46px;
}
#pageAccueil QPushButton#btnAjouter_8:hover {
  background-color: #70381a;
}
#pageAccueil QPushButton#btnAjouter_8:pressed {
  background-color: #4a2408;
}
#pageAccueil QPushButton#btnFaceLogin {
  background-color: rgba(255, 255, 255, 0.4);
  color: #5d2e06;
  border: 2px solid #c9a574;
  border-radius: 11px;
  padding: 10px 18px;
  font: 600 10pt &quot;Segoe UI&quot;;
  min-height: 44px;
}
#pageAccueil QPushButton#btnFaceLogin:hover {
  background-color: rgba(93, 46, 6, 0.07);
  border-color: #8b5e3c;
  color: #4a2405;
}
#pageAccueil QPushButton#btnFaceLogin:pressed {
  background-color: rgba(93, 46, 6, 0.12);
}
#pageAccueil QPushButton#btnForgotPassword {
  background: transparent;
  border: none;
  color: #6b5340;
  font: 600 9pt &quot;Segoe UI&quot;;
  text-align: left;
  padding: 2px 0;
}
#pageAccueil QPushButton#btnForgotPassword:hover {
  color: #5d2e06;
  text-decoration: underline;
}
#pageAccueil QPushButton#btnSignUp {
  background: transparent;
  border: none;
  color: #5d2e06;
  font: 700 9pt &quot;Segoe UI&quot;;
  padding: 2px 6px;
}
#pageAccueil QPushButton#btnSignUp:hover {
  color: #3d1a02;
  text-decoration: underline;
}</string>
