         <property name="styleSheet">
          <string notr="true">#contentStack {
  background-color: #fdfaf3;
}
#contentStack &gt; QWidget {
  background-color: #fdfaf3;
}
#contentStack QGroupBox {
  background-color: #f7fbff;
  border: 1px solid #d9c8b0;
  border-radius: 8px;
  margin-top: 10px;
  padding-top: 14px;
  font-weight: bold;
  font-size: 13px;
  color: #5d2e06;
}
#contentStack QGroupBox::title {
  subcontrol-origin: margin;
  left: 12px;
  padding: 0 6px;
}
#contentStack QLineEdit,
#contentStack QComboBox,
#contentStack QDateEdit,
#contentStack QSpinBox,
#contentStack QDoubleSpinBox,
#contentStack QTextEdit,
#contentStack QPlainTextEdit {
  background-color: #ffffff;
  border: 1px solid #d9c8b0;
  border-radius: 6px;
  padding: 5px 8px;
  font-size: 12px;
  color: #15324a;
  font-weight: normal;
  selection-background-color: #c4a882;
  selection-color: #0b2236;
}
#contentStack QLineEdit:focus,
#contentStack QComboBox:focus,
#contentStack QDateEdit:focus,
#contentStack QSpinBox:focus,
#contentStack QDoubleSpinBox:focus,
#contentStack QTextEdit:focus,
#contentStack QPlainTextEdit:focus {
  border: 1px solid #5d2e06;
}
#contentStack QComboBox::drop-down {
  border: none;
  width: 22px;
}
#contentStack QPushButton {
  background-color: #5d2e06;
  color: #ffffff;
  border: none;
  border-radius: 6px;
  padding: 6px 14px;
  font-weight: bold;
  font-size: 12px;
}
#contentStack QPushButton:hover {
  background-color: #70380a;
}
#contentStack QPushButton:pressed {
  background-color: #4a2405;
}
#contentStack QPushButton:disabled {
  background-color: #b8a894;
  color: #eaf3fb;
}
#contentStack QLabel {
  color: #15324a;
}
#contentStack QTableWidget {
  background-color: #ffffff;
  alternate-background-color: #f9f4e8;
  border: 1px solid #d9c8b0;
  border-radius: 8px;
  gridline-color: #c8def3;
  color: #15324a;
}
#contentStack QTableWidget::item {
  padding: 4px 6px;
}
#contentStack QTableWidget::item:selected {
  background-color: #e8d4b8;
  color: #15324a;
}
#contentStack QHeaderView::section {
  background-color: #5d2e06;
  color: #fdfaf3;
  padding: 6px;
  border: none;
  font-weight: bold;
}
#contentStack QScrollArea {
  background-color: transparent;
  border: none;
}
#contentStack QCalendarWidget {
  background-color: #f7fbff;
}
#contentStack QCalendarWidget QWidget#qt_calendar_navigationbar {
  background-color: #e7f3ff;
}
#contentStack QWidget#verticalLayoutWidget,
#contentStack QWidget#verticalLayoutWidget_6 {
  background-color: #fdfaf3;
}</string>
